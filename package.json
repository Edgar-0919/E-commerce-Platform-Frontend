{
  "name": "ecommerce-frontend-monorepo",
  "private": true,
  "workspaces": [
    "packages/ecommerce-admin",
    "packages/ecommerce-web"
  ],
  "scripts": {
    "dev:admin": "npm run dev --workspace ecommerce-admin",
    "dev:web": "npm run dev --workspace ecommerce-web",
    "build:admin": "npm run build --workspace ecommerce-admin",
    "build:web": "npm run build --workspace ecommerce-web",
    "preview:admin": "npm run preview --workspace ecommerce-admin",
    "preview:web": "npm run preview --workspace ecommerce-web",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces"
  }
}